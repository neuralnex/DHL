# PostgreSQL (required)
# Local: postgresql://postgres:postgres@localhost:5432/logistics_sim
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/logistics_sim

# Redis (required for notification queue; worker)
REDIS_URL=redis://127.0.0.1:6379

# SMTP (required for worker to send mail)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="WestridgeLogistics <noreply@example.com>"

# Public site URL for track links in emails (no trailing slash). Set on Next.js and worker.
PUBLIC_APP_URL=

# Mapbox — tracking map + geocoding on create-shipment
# https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# TypeORM: false in production after migrations
TYPEORM_SYNC=true

# Admin — /beth and POST /api/shipments
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production
# HS256 session secret (min 32 characters)
ADMIN_SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Optional: encrypt SMTP password in DB (defaults to ADMIN_SESSION_SECRET)
SETTINGS_ENCRYPTION_KEY=
